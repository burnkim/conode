{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conode.dev/schema/protocol/v0",
  "title": "conode protocol v0",
  "description": "UI(apps/studio) ↔ engine(conode_engine) WS 메시지 계약. 이 파일이 원천이며 zod/pydantic 양쪽을 생성한다 (R3). 수정 후 `pnpm --filter @conode/schema generate` 재실행.",
  "x-protocol-version": 0,
  "$defs": {
    "ParamValue": {
      "description": "파라미터 값 — number|string|boolean|number[] (MultiMarkerSlider markers).",
      "oneOf": [
        { "type": "number" },
        { "type": "string" },
        { "type": "boolean" },
        { "type": "array", "items": { "type": "number" } }
      ]
    },
    "Category": {
      "type": "string",
      "enum": ["input", "vision", "depth", "generate", "audio", "output"]
    },
    "NodeInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "category", "index"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "$ref": "#/$defs/Category" },
        "index": { "type": "integer" },
        "node_type": { "type": "string" },
        "inputs": { "type": "array", "items": { "type": "string" } },
        "params": { "type": "object", "additionalProperties": true }
      }
    },
    "Hello": {
      "type": "object",
      "description": "핸드셰이크. 연결 직후 양측이 교환.",
      "additionalProperties": false,
      "required": ["type", "v", "role"],
      "properties": {
        "type": { "const": "hello" },
        "v": { "const": 0 },
        "role": { "type": "string", "enum": ["ui", "engine"] },
        "app": { "type": "string" }
      }
    },
    "NodeList": {
      "type": "object",
      "description": "현재 그래프의 노드 목록.",
      "additionalProperties": false,
      "required": ["type", "v", "nodes"],
      "properties": {
        "type": { "const": "node.list" },
        "v": { "const": 0 },
        "nodes": { "type": "array", "items": { "$ref": "#/$defs/NodeInfo" } }
      }
    },
    "ParamSet": {
      "type": "object",
      "description": "파라미터 값 변경 (UI→engine). path 예: 'controlnet.weight'.",
      "additionalProperties": false,
      "required": ["type", "v", "node", "path", "value"],
      "properties": {
        "type": { "const": "param.set" },
        "v": { "const": 0 },
        "node": { "type": "string" },
        "path": { "type": "string" },
        "value": { "$ref": "#/$defs/ParamValue" }
      }
    },
    "FramePreview": {
      "type": "object",
      "description": "프리뷰 프레임 (engine→UI). data = base64(JPEG/WebP). 최종 출력은 UI 경유 금지(R5) — 이건 프리뷰 전용.",
      "additionalProperties": false,
      "required": ["type", "v", "node", "w", "h", "fps", "ms", "format", "seq", "data"],
      "properties": {
        "type": { "const": "frame.preview" },
        "v": { "const": 0 },
        "node": { "type": "string" },
        "w": { "type": "integer" },
        "h": { "type": "integer" },
        "fps": { "type": "number" },
        "ms": { "type": "number" },
        "format": { "type": "string", "enum": ["jpeg", "webp"] },
        "seq": { "type": "integer" },
        "data": { "type": "string" }
      }
    },
    "Edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["src", "dst", "port"],
      "properties": {
        "src": { "type": "string" },
        "dst": { "type": "string" },
        "port": { "type": "string" }
      }
    },
    "GraphGet": {
      "type": "object",
      "description": "현재 그래프 상태 요청 (UI→engine).",
      "additionalProperties": false,
      "required": ["type", "v"],
      "properties": {
        "type": { "const": "graph.get" },
        "v": { "const": 0 }
      }
    },
    "GraphState": {
      "type": "object",
      "description": "그래프 전체 상태 (engine→UI). 변경 시마다 브로드캐스트.",
      "additionalProperties": false,
      "required": ["type", "v", "nodes", "edges"],
      "properties": {
        "type": { "const": "graph.state" },
        "v": { "const": 0 },
        "nodes": { "type": "array", "items": { "$ref": "#/$defs/NodeInfo" } },
        "edges": { "type": "array", "items": { "$ref": "#/$defs/Edge" } }
      }
    },
    "NodeAdd": {
      "type": "object",
      "description": "노드 추가 (UI→engine). node_type 예: 'canny','pose'.",
      "additionalProperties": false,
      "required": ["type", "v", "node_type"],
      "properties": {
        "type": { "const": "node.add" },
        "v": { "const": 0 },
        "node_type": { "type": "string" },
        "id": { "type": "string" }
      }
    },
    "NodeRemove": {
      "type": "object",
      "description": "노드 삭제 (UI→engine).",
      "additionalProperties": false,
      "required": ["type", "v", "node"],
      "properties": {
        "type": { "const": "node.remove" },
        "v": { "const": 0 },
        "node": { "type": "string" }
      }
    },
    "NodeConnect": {
      "type": "object",
      "description": "연결 (UI→engine). src.output → dst.port.",
      "additionalProperties": false,
      "required": ["type", "v", "src", "dst", "port"],
      "properties": {
        "type": { "const": "node.connect" },
        "v": { "const": 0 },
        "src": { "type": "string" },
        "dst": { "type": "string" },
        "port": { "type": "string" }
      }
    },
    "NodeDisconnect": {
      "type": "object",
      "description": "연결 해제 (UI→engine).",
      "additionalProperties": false,
      "required": ["type", "v", "dst", "port"],
      "properties": {
        "type": { "const": "node.disconnect" },
        "v": { "const": 0 },
        "dst": { "type": "string" },
        "port": { "type": "string" }
      }
    },
    "SceneSave": {
      "type": "object",
      "description": "현재 파라미터 상태를 씬으로 저장 (UI→engine).",
      "additionalProperties": false,
      "required": ["type", "v", "name"],
      "properties": {
        "type": { "const": "scene.save" },
        "v": { "const": 0 },
        "name": { "type": "string" }
      }
    },
    "SceneRecall": {
      "type": "object",
      "description": "씬 recall — fade 초 동안 크로스페이드 (UI→engine).",
      "additionalProperties": false,
      "required": ["type", "v", "name"],
      "properties": {
        "type": { "const": "scene.recall" },
        "v": { "const": 0 },
        "name": { "type": "string" },
        "fade": { "type": "number" }
      }
    },
    "SceneGet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "v"],
      "properties": {
        "type": { "const": "scene.get" },
        "v": { "const": 0 }
      }
    },
    "SceneList": {
      "type": "object",
      "description": "씬 목록 (engine→UI).",
      "additionalProperties": false,
      "required": ["type", "v", "names"],
      "properties": {
        "type": { "const": "scene.list" },
        "v": { "const": 0 },
        "names": { "type": "array", "items": { "type": "string" } }
      }
    },
    "CueBind": {
      "type": "object",
      "description": "이벤트→씬 큐 바인딩 (UI→engine). 제스처/OSC 이벤트가 씬을 recall.",
      "additionalProperties": false,
      "required": ["type", "v", "event", "scene"],
      "properties": {
        "type": { "const": "cue.bind" },
        "v": { "const": 0 },
        "event": { "type": "string" },
        "scene": { "type": "string" },
        "fade": { "type": "number" }
      }
    },
    "ModCellSpec": {
      "type": "object",
      "description": "ModMatrix 셀 — source→target 라우팅 (amount/curve/smooth).",
      "additionalProperties": false,
      "required": ["source", "target", "amount", "curve", "smooth_ms"],
      "properties": {
        "source": { "type": "string" },
        "target": { "type": "string" },
        "amount": { "type": "number" },
        "curve": { "type": "string" },
        "smooth_ms": { "type": "number" }
      }
    },
    "ModMatrixGet": {
      "type": "object",
      "description": "ModMatrix 상태 요청 (UI→engine). node 생략 시 첫 mod_matrix.",
      "additionalProperties": false,
      "required": ["type", "v"],
      "properties": {
        "type": { "const": "modmatrix.get" },
        "v": { "const": 0 },
        "node": { "type": "string" }
      }
    },
    "ModMatrixState": {
      "type": "object",
      "description": "ModMatrix 상태 (engine→UI). 가용 소스/타깃 + 활성 셀. 변경 시 브로드캐스트.",
      "additionalProperties": false,
      "required": ["type", "v", "node", "sources", "targets", "curves", "cells"],
      "properties": {
        "type": { "const": "modmatrix.state" },
        "v": { "const": 0 },
        "node": { "type": "string" },
        "sources": { "type": "array", "items": { "type": "string" } },
        "targets": { "type": "array", "items": { "type": "string" } },
        "curves": { "type": "array", "items": { "type": "string" } },
        "cells": { "type": "array", "items": { "$ref": "#/$defs/ModCellSpec" } }
      }
    },
    "ModCellSet": {
      "type": "object",
      "description": "ModMatrix 셀 설정/갱신 (UI→engine). (source,target) upsert.",
      "additionalProperties": false,
      "required": ["type", "v", "node", "source", "target", "amount"],
      "properties": {
        "type": { "const": "modmatrix.cell.set" },
        "v": { "const": 0 },
        "node": { "type": "string" },
        "source": { "type": "string" },
        "target": { "type": "string" },
        "amount": { "type": "number" },
        "curve": { "type": "string" },
        "smooth_ms": { "type": "number" }
      }
    },
    "ModCellClear": {
      "type": "object",
      "description": "ModMatrix 셀 제거 (UI→engine).",
      "additionalProperties": false,
      "required": ["type", "v", "node", "source", "target"],
      "properties": {
        "type": { "const": "modmatrix.cell.clear" },
        "v": { "const": 0 },
        "node": { "type": "string" },
        "source": { "type": "string" },
        "target": { "type": "string" }
      }
    },
    "Message": {
      "description": "모든 프로토콜 메시지의 판별 유니온 (discriminator: type).",
      "oneOf": [
        { "$ref": "#/$defs/Hello" },
        { "$ref": "#/$defs/NodeList" },
        { "$ref": "#/$defs/ParamSet" },
        { "$ref": "#/$defs/FramePreview" },
        { "$ref": "#/$defs/GraphGet" },
        { "$ref": "#/$defs/GraphState" },
        { "$ref": "#/$defs/NodeAdd" },
        { "$ref": "#/$defs/NodeRemove" },
        { "$ref": "#/$defs/NodeConnect" },
        { "$ref": "#/$defs/NodeDisconnect" },
        { "$ref": "#/$defs/SceneSave" },
        { "$ref": "#/$defs/SceneRecall" },
        { "$ref": "#/$defs/SceneGet" },
        { "$ref": "#/$defs/SceneList" },
        { "$ref": "#/$defs/CueBind" },
        { "$ref": "#/$defs/ModMatrixGet" },
        { "$ref": "#/$defs/ModMatrixState" },
        { "$ref": "#/$defs/ModCellSet" },
        { "$ref": "#/$defs/ModCellClear" }
      ]
    }
  },
  "$ref": "#/$defs/Message"
}
